# Telegram API Credentials
API_ID=
API_HASH=

# Telegram phone number (with country code, e.g. +1234567890)
TELEGRAM_PHONE=

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/telegram_export

# Logging
LOG_LEVEL=INFO

# Parser settings
MAX_WORKERS=5
BATCH_SIZE=1000

# Optional AI providers (for local_ai_chat.py)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_MODEL=gpt-5.3-codex
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
