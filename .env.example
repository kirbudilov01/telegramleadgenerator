# Environment Overrides for Threads Autopilot + X Agent
# Copy this file to .env and fill in your values

# ============================================================================
# GITHUB MODELS (LLM for both agents - PRIMARY)
# ============================================================================
# Generate at: https://github.com/settings/tokens (no scopes needed)
# REQUIRED for Threads autopilot (uses GitHub Models API)
# OPTIONAL for X agent (currently uses OpenRouter, but can be fallback)
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# ============================================================================
# OPENROUTER (LLM fallback for X agent)
# ============================================================================
# Get key at: https://openrouter.ai/keys
# Currently used by X agent; can be replaced with GitHub Models
OPENROUTER_API_KEY=sk-or-YOUR_KEY_HERE

# ============================================================================
# THREADS AUTOPILOT - WINDOW/RESOLUTION OVERRIDES
# ============================================================================
# Override window position and size (useful for multi-monitor or Linux)
# Default: x=0, y=0, width=960, height=1080
# 
# Example for 1366x768 Linux:
#   THREADS_WIN_X=0
#   THREADS_WIN_Y=0
#   THREADS_WIN_WIDTH=660
#   THREADS_WIN_HEIGHT=720
#
# Example for 1920x1080 Linux:
#   THREADS_WIN_X=0
#   THREADS_WIN_Y=0
#   THREADS_WIN_WIDTH=940
#   THREADS_WIN_HEIGHT=1040

THREADS_WIN_X=0
THREADS_WIN_Y=0
THREADS_WIN_WIDTH=960
THREADS_WIN_HEIGHT=1080

# ============================================================================
# X AGENT - BROWSER VIEWPORT OVERRIDES
# ============================================================================
# Override Puppeteer browser viewport and position
# Default: x=970, y=0, width=950, height=1080 (next to Threads on macOS)
#
# Example for side-by-side on 1366x768 Linux (split screen):
#   X_BROWSER_X=680
#   X_BROWSER_Y=0
#   X_BROWSER_WIDTH=660
#   X_BROWSER_HEIGHT=720

X_BROWSER_X=970
X_BROWSER_Y=0
X_BROWSER_WIDTH=950
X_BROWSER_HEIGHT=1080

# ============================================================================
# TMUX DUAL-PANE LAUNCHER (go.sh start)
# ============================================================================
# Control tmux session layout and size
# Default: even-horizontal, 240 columns, 60 rows
#
# DUAL_LAYOUT options: even-horizontal, even-vertical, main-horizontal, main-vertical
# DUAL_TMUX_WIDTH: total columns for both panes
# DUAL_TMUX_HEIGHT: total rows

DUAL_LAYOUT=even-horizontal
DUAL_TMUX_WIDTH=240
DUAL_TMUX_HEIGHT=60

# ============================================================================
# OPTIONAL: LOCAL LLM (Ollama)
# ============================================================================
# If you want to use local LLM instead of GitHub Models
# Requires: ollama serve running on localhost:11434
# Currently NOT recommended (slow, limited reasoning)

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# ============================================================================
# OPTIONAL: DEBUG/LOGGING
# ============================================================================
# Set to 1 to enable verbose logging
DEBUG=0
VERBOSE=0

# ============================================================================
# QUICK SETUP FOR DIFFERENT SCREENS
# ============================================================================
#
# macOS 13" Retina (default):
#   - Don't set these vars, use config.json defaults
#
# Linux 1366x768 (1/2 screen each):
#   DUAL_TMUX_WIDTH=200
#   DUAL_TMUX_HEIGHT=45
#   THREADS_WIN_WIDTH=660
#   THREADS_WIN_HEIGHT=720
#   X_BROWSER_X=680
#   X_BROWSER_WIDTH=660
#   X_BROWSER_HEIGHT=720
#
# Linux 1920x1080 (1/2 screen each):
#   DUAL_TMUX_WIDTH=240
#   DUAL_TMUX_HEIGHT=60
#   THREADS_WIN_WIDTH=940
#   THREADS_WIN_HEIGHT=1040
#   X_BROWSER_X=960
#   X_BROWSER_WIDTH=940
#   X_BROWSER_HEIGHT=1040
#
# Linux 2560x1440 (1/2 screen each):
#   DUAL_TMUX_WIDTH=280
#   DUAL_TMUX_HEIGHT=70
#   THREADS_WIN_WIDTH=1240
#   THREADS_WIN_HEIGHT=1300
#   X_BROWSER_X=1260
#   X_BROWSER_WIDTH=1240
#   X_BROWSER_HEIGHT=1300
